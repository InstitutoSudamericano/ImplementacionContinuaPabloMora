generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/client-activity"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_ACTIVITY_URL")
}

enum InteractionType {
  LIKE
  DISLIKE
  AVOID
  REPORT
}

enum LiveSessionState {
  CREATED
  LIVE
  ENDED
}

model Interaction {
  id         String          @id @default(uuid())
  fromUserId String
  toUserId   String
  type       InteractionType
  reason     String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([fromUserId, toUserId])
}

model Match {
  id        String   @id @default(uuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  chat      Chat?

  @@unique([userAId, userBId])
}

model Chat {
  id        String    @id @default(uuid())
  matchId   String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  match     Match     @relation(fields: [matchId], references: [id])
  messages  Message[]
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  senderId  String
  content   String
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id])
}

model MusicItem {
  id         String   @id @default(uuid())
  userId     String
  title      String
  artist     String
  spotifyUrl String?
  source     String   @default("SPOTIFY_MOCK")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model LiveStatus {
  id               String   @id @default(uuid())
  userId           String   @unique
  isOnline         Boolean  @default(false)
  isLiveEnabled    Boolean  @default(false)
  currentLiveTitle String?
  updatedAt        DateTime @updatedAt
}

model LiveSession {
  id          String           @id @default(uuid())
  userId      String
  title       String
  description String?
  status      LiveSessionState @default(CREATED)
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}
